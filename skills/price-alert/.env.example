# Twelve Data API Key（免费申请：https://twelvedata.com/）
TWELVE_DATA_API_KEY=your_api_key_here

# Telegram Bot（@BotFather 创建 bot 获取 token）
TELEGRAM_BOT_TOKEN=your_bot_token_here
# 获取 chat_id：向 bot 发消息后访问 https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# 波动阈值（1 小时窗口内涨跌幅百分比）
XAU_THRESHOLD_PCT=2.0
BTC_THRESHOLD_PCT=5.0

# 时间窗口（分钟，1440 = 24小时）
WINDOW_MINUTES=1440

# 告警升级步长（百分点）— 波动率比上次告警扩大多少才再次告警（默认 3）
# 例：BTC 阈值 5%，首次 5.2% 告警，下次要到 8.2% 才再告警，再下次 11.2%
# 波动回落到阈值以下时自动重置
ALERT_STEP_PCT=3.0
