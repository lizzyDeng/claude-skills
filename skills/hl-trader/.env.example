# Hyperliquid 私钥（建议使用 Wallet Agent 子密钥，不要用主钱包私钥）
# 如果用 Agent 子密钥，需同时设置 HL_ACCOUNT_ADDRESS 为主钱包地址
HL_PRIVATE_KEY=0x_your_private_key_here

# 主钱包地址（仅使用 Agent 子密钥时需要填写）
HL_ACCOUNT_ADDRESS=

# 是否使用测试网（true = testnet, false = mainnet）
HL_TESTNET=true

# Telegram 通知（复用 price-alert 的配置）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
